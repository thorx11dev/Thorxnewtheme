DATABASE_URL=postgresql://user:pass@host:5432/db
SESSION_SECRET=your-64-char-random-hex-string-generate-using-crypto
FRONTEND_ORIGINS=https://thorx.pro,https://www.thorx.pro
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_DOMAIN=
PORT=5000
NODE_ENV=production
DB_PROVIDER=insforge
AUTH_PROVIDER=insforge
STORAGE_PROVIDER=insforge

# Frontend runtime
VITE_API_URL=https://api.thorx.pro
VITE_AUTH_PROVIDER=insforge
# Firebase Configuration (optional fallback mode)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Admin (Server-side)
# Get this from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Copy the entire JSON content into the variable below (no spaces or newlines)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# Insforge variables
INSFORGE_API_URL=https://jxrh4q8k.ap-southeast.insforge.app
INSFORGE_API_KEY=replace_with_api_key
INSFORGE_ANON_KEY=replace_with_anon_key

# Optional hardening for /api/proxy in production
PROXY_ALLOWED_HOSTS=thorx.pro,www.thorx.pro
