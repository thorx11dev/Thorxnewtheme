# --- Postgres (required) ---
# Auto-injected by Replit's managed PostgreSQL. Only needed for external hosting.
DATABASE_URL=postgresql://user:pass@host:5432/db

# --- Express session (required) ---
# Random 64-char hex string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-64-char-random-hex-string

# --- Production-only hardening (leave unset in development) ---
FRONTEND_ORIGINS=https://yourdomain.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_DOMAIN=.yourdomain.com
PORT=5000
NODE_ENV=production

# One-time secret required to call POST /api/bootstrap-founder in development.
BOOTSTRAP_SECRET=

# Optional: encrypts sensitive credential fields at rest. Falls back to SESSION_SECRET if unset.
CREDENTIAL_ENCRYPTION_KEY=

# Optional hardening for /api/proxy in production
PROXY_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# --- Vite client (build-time) ---
# Leave unset for same-origin deployment (API and client served from the same Express server).
# Only set if the API is hosted on a different origin than the client.
# VITE_API_URL=https://api.yourdomain.com
