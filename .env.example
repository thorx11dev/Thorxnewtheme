# --- Postgres (required) ---
# Use your Insforge project's PostgreSQL connection string when hosted on Insforge Cloud.
DATABASE_URL=postgresql://user:pass@host:5432/db

# --- Express session (required in production) ---
SESSION_SECRET=your-64-char-random-hex-string-generate-using-crypto
FRONTEND_ORIGINS=https://thorx.pro,https://www.thorx.pro
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=none
# Split hosting: share session cookie between thorx.pro and api.thorx.pro
SESSION_COOKIE_DOMAIN=.thorx.pro
PORT=5000
NODE_ENV=production

# --- Insforge Auth + Storage (server) ---
# Must be the same Insforge project origin as VITE_INSFORGE_URL on the client.
INSFORGE_API_URL=https://your-project.ap-southeast.insforge.app
# Service / admin key: required for storage uploads and for GET /api/config/insforge (anon key passthrough).
INSFORGE_API_KEY=
# Public anon key (same value as VITE_INSFORGE_ANON_KEY) — exposed only via GET /api/config/insforge for the SPA.
INSFORGE_ANON_KEY=

# Bucket for profile images (must exist in Insforge; default matches MCP-created `thorx-assets`).
INSFORGE_STORAGE_BUCKET=thorx-assets

# If the bucket is private, set this to the public origin of THIS API (e.g. https://api.thorx.pro) so profile
# URLs are rewritten to GET /api/thorx/storage-proxy?u=... which streams with INSFORGE_API_KEY.
THORX_PUBLIC_API_URL=https://api.thorx.pro

# Set to `true` only if the bucket allows anonymous read on object URLs (then THORX_PUBLIC_API_URL is not needed for avatars).
INSFORGE_STORAGE_PUBLIC_READ=false

# Max GET requests per IP per minute for /api/thorx/storage-proxy (default 120).
STORAGE_PROXY_RATE_LIMIT_MAX=120

# Optional hardening for /api/proxy in production
PROXY_ALLOWED_HOSTS=thorx.pro,www.thorx.pro

# --- Vite client (build-time) ---
# Browser calls THORX API here (must match cookie/CORS and THORX_PUBLIC_API_URL host when using the storage proxy).
VITE_API_URL=https://api.thorx.pro
# Same Insforge project as INSFORGE_API_URL (no trailing slash).
VITE_INSFORGE_URL=https://your-project.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key
